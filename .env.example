# Em dev deixe vazio para usar o proxy do Vite (/api → localhost:3001)
VITE_API_BASE_URL=

# OAuth — mesmo Client ID do backend (Google Cloud Console / Apple Developer)
# Sem isso, os botões sociais ficam ocultos
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
# Domínio autorizado no Sign in with Apple (Services ID)
VITE_APPLE_REDIRECT_URI=http://localhost:5173
